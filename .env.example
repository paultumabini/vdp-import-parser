## Django core
# Set to false in production.
DJANGO_DEBUG=true

# Replace in production with a long random secret.
DJANGO_SECRET_KEY=django-insecure-change-me-in-production

# Comma-separated list. Examples:
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_ALLOWED_HOSTS=app.example.com,www.app.example.com
DJANGO_ALLOWED_HOSTS=*

# Security overrides used when DJANGO_DEBUG=false
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

## Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=vdp
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=127.0.0.1
DB_PORT=5432

## External APIs / scripts
# AIM API sync script (`vdpurls/aimapi.py`)
AVAIM_EMAIL=
AVAIM_PASS=
